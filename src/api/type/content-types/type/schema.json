{
  "kind": "collectionType",
  "collectionName": "types",
  "info": {
    "singularName": "type",
    "pluralName": "types",
    "displayName": "Tour Type",
    "description": "Tour type filter like Expert-led journeys, Small Group Departures, etc."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "tours": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tour.tour",
      "mappedBy": "type"
    }
  }
}
